datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Scan {
  id              Int      @id @default(autoincrement())
  name            String
  acquisitionTime DateTime
  bbox_min_lon    Float
  bbox_min_lat    Float
  bbox_max_lon    Float
  bbox_max_lat    Float
  storageUrlRaw   String
  storageUrlHdr   String
  uploadedAt      DateTime @default(now())
}
